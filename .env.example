# Local-dev secrets for the router. Copy to `.env` (git-ignored) and fill in.
#
# The router reads `ROUTER__*` overrides from the process environment (the `config`
# crate, `Environment::with_prefix("ROUTER").separator("__")`). Source this file
# before running, so the keys never live in a tracked config file:
#
#   set -a; source .env; set +a
#   cargo run --bin router -- -f config/development.toml

RUN_ENV=development

# Local-dev convenience: this points the primary at Fixer. The committed config files default
# to `open_exchange_rates`; override here only for local runs.
ROUTER__FOREX_API__PROVIDER=fixer
ROUTER__FOREX_API__FALLBACK_PROVIDER=currency_layer

# Open Exchange Rates app id
ROUTER__FOREX_API__API_KEY=
# Currency Layer (apilayer.net) access key
ROUTER__FOREX_API__FALLBACK_API_KEY=
# data.fixer.io access key
ROUTER__FOREX_API__FIXER_API_KEY=

# forex_enabled is an [analytics] flag (not [forex_api]); enable amount normalisation locally:
ROUTER__ANALYTICS__FOREX_ENABLED=true
